PORT=5000
NODE_ENV=development
API_PREFIX=/api
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Legacy service key (optional); dashboard uses JWT from /admin/auth/login
ADMIN_API_SECRET=lavey-admin-dev-secret
ADMIN_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Required for new admin sign-ups after the first account exists
# Required in Invite code field when registering a 2nd+ admin (default below)
ADMIN_REGISTER_SECRET=lavey-admin-register-dev

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Must match an "Authorized redirect URI" on your Google OAuth Web client exactly.
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
