# Copy to .env.production (or merge) before `npm run build:mobile`
# Production API + Supabase — same values as your Netlify deploy.

VITE_API_BASE_URL=https://laveybackend-3.onrender.com/api
VITE_USE_MOCK_API=false
VITE_USE_REAL_AUTH=true

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Optional — Google sign-in on mobile (configure OAuth client for Android in Google Cloud)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# --- Render backend (required for Android sign-in) ---
# Add these origins to CORS_ORIGIN on Render (comma-separated), e.g.:
# CORS_ORIGIN=https://loviey.netlify.app,http://localhost:3000,https://localhost,http://localhost,capacitor://localhost
#
# Supabase → Authentication → URL configuration → Redirect URLs, add:
# https://localhost/**
# capacitor://localhost/**
